# Messaging feature toggles
MESSAGING_DISPATCH_ENABLED=true
MESSAGING_DISPATCH_BATCH=10
MESSAGING_REMINDERS_ENABLED=true
MESSAGING_REMINDER_WINDOW=30
MESSAGING_BIRTHDAYS_ENABLED=true

# Stripe configuration
# For local development only. In production prefer Firebase Secret Manager (STRIPE_SECRET_KEY).
STRIPE_SECRET_KEY=replace-with-live-or-test-key
STRIPE_WEBHOOK_SECRET=replace-with-webhook-signing-secret
STRIPE_APPLICATION_FEE_AMOUNT=0
STRIPE_PLATFORM_NAME=YOUBOOK
STRIPE_ALLOWED_ORIGIN=https://youbook.civiapp.it



